rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/staff/$(request.auth.uid))
             ? get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role
             : null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Admin';
    }

    function isManager() {
      return isAuthenticated() && getUserRole() == 'Manager';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'Staff';
    }

    function isUpdatingRestrictedStaffFields() {
      // Prevent updates to sensitive staff fields
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'active', 'id', 'email']);
    }

    function isAssignedToAuth(rsc) {
      // Supports direct assignment (assignedStaffId) or indirect via taskId
      return rsc.get('assignedStaffId', null) == request.auth.uid ||
             (rsc.get('taskId', null) != null && get(/databases/$(database)/documents/tasks/$(rsc.taskId)).data.get('assignedStaffId', null) == request.auth.uid);
    }

    // ========================================================================
    // DEFAULT DENY
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ========================================================================
    // STAFF COLLECTION
    // Admin: full access
    // Manager: read all staff, update only allowed fields
    // Staff: read/update only their own document, cannot change sensitive fields
    // ========================================================================
    match /staff/{staffId} {
      // Allow registration of self as Staff. Admins can create anyone.
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == staffId && request.resource.data.role == 'Staff');
      
      allow read: if isAdmin() || isManager() || (isAuthenticated() && request.auth.uid == staffId);
      
      allow update: if isAdmin() || 
                       (isManager() && !isUpdatingRestrictedStaffFields()) || 
                       (isAuthenticated() && request.auth.uid == staffId && !isUpdatingRestrictedStaffFields());
                       
      allow delete: if isAdmin();
    }

    // ========================================================================
    // CLIENTS COLLECTION
    // Admin, Manager: full access
    // Staff: only assigned clients
    // ========================================================================
    match /clients/{clientId} {
      allow read, update, delete: if isAdmin() || isManager() || 
                                     (isStaff() && resource.data.get('assignedStaffId', null) == request.auth.uid);
      allow create: if isAdmin() || isManager() || 
                       (isStaff() && request.resource.data.get('assignedStaffId', null) == request.auth.uid);
    }

    // ========================================================================
    // TASKS COLLECTION
    // Admin, Manager: full access
    // Staff: assigned tasks only
    // ========================================================================
    match /tasks/{taskId} {
      allow read, update, delete: if isAdmin() || isManager() || 
                                     (isStaff() && resource.data.get('assignedStaffId', null) == request.auth.uid);
      allow create: if isAdmin() || isManager() || 
                       (isStaff() && request.resource.data.get('assignedStaffId', null) == request.auth.uid);
    }

    // ========================================================================
    // REMINDERS & REMINDER_HISTORY COLLECTION
    // Admin, Manager: full access
    // Staff: assigned reminders only
    // ========================================================================
    match /reminders/{reminderId} {
      allow read, update, delete: if isAdmin() || isManager() || (isStaff() && isAssignedToAuth(resource.data));
      allow create: if isAdmin() || isManager() || (isStaff() && isAssignedToAuth(request.resource.data));
    }
    
    match /reminder_history/{historyId} {
      allow read, update, delete: if isAdmin() || isManager() || (isStaff() && isAssignedToAuth(resource.data));
      allow create: if isAdmin() || isManager() || (isStaff() && isAssignedToAuth(request.resource.data));
    }

    // ========================================================================
    // PAYMENTS COLLECTION
    // Admin: full access
    // Manager: read only
    // Staff: no access
    // ========================================================================
    match /payments/{paymentId} {
      allow read: if isAdmin() || isManager();
      allow write: if isAdmin();
    }

    // ========================================================================
    // DOCUMENTS COLLECTION
    // Admin: full access
    // Manager: assigned documents
    // Staff: assigned documents only
    // ========================================================================
    match /documents/{documentId} {
      allow read, update, delete: if isAdmin() || 
          ((isManager() || isStaff()) && resource.data.get('assignedStaffId', null) == request.auth.uid);
      allow create: if isAdmin() || 
          ((isManager() || isStaff()) && request.resource.data.get('assignedStaffId', null) == request.auth.uid);
    }

    // ========================================================================
    // AUDIT_LOGS COLLECTION
    // Anyone authenticated may create logs.
    // Nobody may update or delete logs.
    // Admin may read.
    // ========================================================================
    match /audit_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ========================================================================
    // SYSTEM_CONFIG COLLECTION
    // Admin only
    // ========================================================================
    match /system_config/{configId} {
      allow read, write: if isAdmin();
    }
    
    // ========================================================================
    // SETTINGS / TEMPLATES
    // ========================================================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager();
    }

    // ========================================================================
    // REMINDER_SETTINGS COLLECTION
    // Admin full access
    // Manager read only
    // Staff no access
    // ========================================================================
    match /reminder_settings/{settingId} {
      allow read: if isAdmin() || isManager();
      allow write: if isAdmin();
    }

    // ========================================================================
    // ADDITIONAL COLLECTIONS (If any remain)
    // ========================================================================
    match /pending_users/{userId} {
      allow read, write: if isAdmin();
    }

    match /staff_tokens/{tokenId} {
      // Allow users to update their own tokens
      allow read, update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }
  }
}
